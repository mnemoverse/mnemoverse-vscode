{
  "name": "mnemoverse-vscode",
  "displayName": "Mnemoverse Memory",
  "description": "Persistent memory for GitHub Copilot Chat Agent Mode. Your memories sync across Claude, Cursor, ChatGPT, and other Mnemoverse-connected tools.",
  "version": "0.2.0",
  "publisher": "Mnemoverse",
  "preview": true,
  "pricing": "Free",
  "license": "MIT",
  "homepage": "https://mnemoverse.com/docs/api/mcp-server",
  "bugs": {
    "url": "https://github.com/mnemoverse/mnemoverse-vscode/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mnemoverse/mnemoverse-vscode.git"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/mnemoverse"
  },
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "ai-agent",
    "copilot",
    "copilot-chat",
    "agent-mode",
    "mnemoverse",
    "persistent-memory",
    "shared-memory",
    "cross-tool",
    "model-context-protocol"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0b1020",
    "theme": "dark"
  },
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "This extension spawns the @mnemoverse/mcp-memory-server npm package via npx. Running arbitrary third-party code requires a trusted workspace."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "This extension spawns a local process via npx, which is unavailable in virtual workspaces such as github.dev or vscode.dev."
    }
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "mnemoverse.memory",
        "label": "Mnemoverse Memory"
      }
    ],
    "commands": [
      {
        "command": "mnemoverse.signIn",
        "title": "Sign In",
        "category": "Mnemoverse"
      },
      {
        "command": "mnemoverse.signOut",
        "title": "Sign Out",
        "category": "Mnemoverse"
      },
      {
        "command": "mnemoverse.setApiKey",
        "title": "Set API Key (paste manually)",
        "category": "Mnemoverse"
      },
      {
        "command": "mnemoverse.clearApiKey",
        "title": "Clear API Key",
        "category": "Mnemoverse"
      },
      {
        "command": "mnemoverse.openDocs",
        "title": "Open Documentation",
        "category": "Mnemoverse"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
